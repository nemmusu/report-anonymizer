packaging/appimage/build-cache/
packaging/appimage/dist/

# .deb build artefacts (staged AppDir + final .deb). The build
# script regenerates them from the project tree on every run.
packaging/deb/build-cache/
packaging/deb/dist/

/image_inventory.yml
/.anon/

# Bundled GGUF models (kept locally for benchmarking only)
*.gguf
model/

# Windows build artifacts (Fase 2+)
packaging/windows/build-cache/
packaging/windows/staging/
packaging/windows/dist/
packaging/windows/launcher/*.exe
packaging/windows/launcher/*.ico
packaging/windows/launcher/*.res
packaging/windows/launcher/app_icon_*.gen.rc
packaging/windows/PLAN.md
# Per-run build / installer / smoke-test transcripts that the
# packaging scripts dump into the same folder; we don't version
# them, the workflow logs already preserve them in CI.
packaging/windows/*.log
packaging/windows/*.err.log
packaging/windows/*.log.err
packaging/windows/nul.pdf
packaging/windows/iscc.log
packaging/windows/iscc.err.log
packaging/windows/.iscc-current-pid.txt
packaging/windows/.iscc-current-stamp.txt

# Local pytest basetemp override (see tests/conftest.py docstring).
.pytest_tmp/

