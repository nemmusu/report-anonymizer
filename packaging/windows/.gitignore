# Local .gitignore for packaging/windows/.
# The repo-root .gitignore already excludes these paths; this file is kept
# as a defence-in-depth so that running tools from inside packaging/windows/
# (e.g. a clean checkout, or a shell that ignores the parent .gitignore)
# still does the right thing.

# Build infrastructure cache: 7zr, Inno Setup portable, MinGW WinLibs.
# Recreated on demand by scripts/bootstrap-tools.ps1.
build-cache/

# Staging tree assembled by scripts/stage-app.ps1. ~1.5 GB during build.
staging/

# Final Setup.exe output (~225-405 MB).
dist/

# Compiled launcher artefacts. Regenerated by scripts/compile-launchers.ps1.
launcher/*.exe
launcher/*.res
launcher/*.ico
launcher/*.o
launcher/*.obj

# Legacy design doc. Replaced by README.md (this directory's how-to-build).
PLAN.md
